{
    "name": "maatify/seo",
    "description": "Standalone SEO library for metadata, JSON-LD, sitemaps, hreflang, redirects, slug history, and SEO validation.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "seo",
        "metadata",
        "json-ld",
        "schema",
        "sitemap",
        "hreflang",
        "robots",
        "canonical",
        "open-graph",
        "twitter-card"
    ],
    "homepage": "https://github.com/Maatify/seo",
    "support": {
        "issues": "https://github.com/Maatify/seo/issues",
        "source": "https://github.com/Maatify/seo"
    },
    "authors": [
        {
            "name": "Maatify",
            "homepage": "https://maatify.dev"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-xmlwriter": "*"
    },
    "autoload": {
        "psr-4": {
            "Maatify\\Seo\\": "src/"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2"
    },
    "suggest": {
        "spatie/schema-org": "Optional integration for converting Spatie schema objects into Maatify JSON-LD DTOs."
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
